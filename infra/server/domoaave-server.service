[Unit]
Description=Domoaave Alert Server
After=network.target

[Service]
User=jehrlich
WorkingDirectory=/home/jehrlich/domoaave
Environment="API_KEY=xxx"
ExecStart=/home/jehrlich/domoaave/venv/bin/gunicorn -w 2 -b 0.0.0.0:6000 server:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

